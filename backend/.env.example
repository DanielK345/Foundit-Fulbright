GEMINI_API_KEY=your_gemini_key

# Best quality: Gemini writes final questions; Ollama handles local extraction/refinement/judging.
AI_TEXT_PROVIDER=gemini
AI_EMBED_PROVIDER=ollama

GEMINI_MODEL=gemini-2.0-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_TEXT_MODEL=qwen3:14b
OLLAMA_EXTRACT_MODEL=qwen3:14b
OLLAMA_QUESTION_MODEL=qwen3:14b
OLLAMA_JUDGE_MODEL=qwen3:14b
OLLAMA_NUM_CTX=16384
OLLAMA_KEEP_ALIVE=10m

# Keep review page fast. Enable only if you are okay waiting longer on course-map review.
ENABLE_LOCAL_COURSE_MAP_REFINEMENT=false

CORS_ORIGINS=http://localhost:3000
